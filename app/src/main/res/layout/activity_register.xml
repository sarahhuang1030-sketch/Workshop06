<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8ECF5"
    android:fillViewport="true"
    tools:context=".RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_register_card"
            android:padding="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp">

            <!-- Account Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account Type"
                android:textColor="#111827"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerAccountType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <!-- First + Last -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="First Name"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="textPersonName"
                        android:textColor="#111827"
                        android:textColorHint="#94A3B8" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Name"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etLastName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="textPersonName"
                        android:textColor="#111827"
                        android:textColorHint="#94A3B8" />
                </LinearLayout>
            </LinearLayout>

            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone"
                android:textColor="#111827"
                android:textSize="14sp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="403-999-8888"
                android:inputType="phone"
                android:textColor="#111827"
                android:textColorHint="#64748B" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="#111827"
                android:textSize="14sp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="you@example.com"
                android:inputType="textEmailAddress"
                android:textColor="#111827"
                android:textColorHint="#64748B" />

            <!-- Username -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textColor="#111827"
                android:textSize="14sp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Choose a username"
                android:inputType="text"
                android:textColor="#111827"
                android:textColorHint="#64748B" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="#111827"
                android:textSize="14sp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="textPassword"
                    android:textColor="#111827"
                    android:textColorHint="#64748B" />

                <ImageButton
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_password_toggle"
                    android:src="@drawable/ic_eye"
                    android:contentDescription="Show password"
                    android:padding="12dp" />
            </LinearLayout>

            <!-- Confirm Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm Password"
                android:textColor="#111827"
                android:textSize="14sp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field">

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="textPassword"
                    android:textColor="#111827"
                    android:textColorHint="#64748B" />

                <ImageButton
                    android:id="@+id/btnToggleConfirmPassword"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_password_toggle"
                    android:src="@drawable/ic_eye"
                    android:contentDescription="Show confirm password"
                    android:padding="12dp" />
            </LinearLayout>

            <!-- Street 1 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Street 1"
                android:textColor="#111827"
                android:textSize="14sp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etStreet1"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="textPostalAddress"
                android:textColor="#111827"
                android:textColorHint="#64748B" />

            <!-- Street 2 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Street 2 (optional)"
                android:textColor="#111827"
                android:textSize="14sp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etStreet2"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="textPostalAddress"
                android:textColor="#111827"
                android:textColorHint="#64748B" />

            <!-- City + Province -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="City"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etCity"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="textCapWords"
                        android:textColor="#111827"
                        android:textColorHint="#64748B" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Province"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etProvince"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="textCapWords"
                        android:textColor="#111827"
                        android:textColorHint="#64748B" />
                </LinearLayout>
            </LinearLayout>

            <!-- Postal Code + Country -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Postal Code"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etPostalCode"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="text"
                        android:textColor="#111827"
                        android:textColorHint="#64748B" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Country"
                        android:textColor="#111827"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etCountry"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="Canada"
                        android:textColor="#111827"
                        android:textColorHint="#64748B" />
                </LinearLayout>
            </LinearLayout>

            <!-- Submit -->
            <Button
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_button_gradient_larger" />

            <!-- Sign in -->
            <TextView
                android:id="@+id/tvSignIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:text="Already have an account? Sign in"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>