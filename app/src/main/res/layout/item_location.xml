<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#EDE8FB"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLocationName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#2D1F5E"
                android:text="Downtown Sales Office" />

            <TextView
                android:id="@+id/tvLocationType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SalesPoint"
                android:textColor="#8A89C8"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvLocationCity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calgary, AB"
                android:textColor="#8A89C8"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEditLocation"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#6F56B3"/>

        <ImageButton
            android:id="@+id/btnDeleteLocation"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#D94B7D"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>