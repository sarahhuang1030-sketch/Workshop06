<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT PLAN"
                android:textColor="#A855F7"
                android:textStyle="bold"
                android:textSize="10sp"
                android:background="@drawable/bg_tag_light_purple"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tvPlanPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="$0.00"
                android:textColor="#A855F7"
                android:textStyle="bold"
                android:textSize="22sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/mo"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPlanName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Active Plan"
            android:textColor="#111827"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/tvPlanSubInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subscription"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tvPlanAddonInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No active add-ons"
            android:textColor="#9CA3AF"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>